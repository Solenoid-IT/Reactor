// @enabled FALSE
// @mutex FALSE

// @on MESSAGE



import { Event, MessageEvent, log } from 'core';



export async function run (event : Event)
{
	if (!(event instanceof MessageEvent)) {
		return;
	}

	await log('message from ' + (event.data.senderName || event.data.sender || 'unknown') + ': ' + (event.data.content || ''));
}
