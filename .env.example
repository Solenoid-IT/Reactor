# Reactor timeout tuning (milliseconds)
# TURN credential test timeout used by Settings -> TURN save/test.
REACTOR_TURN_TEST_TIMEOUT_MS=12000

# P2P remote endpoints request timeout used by Network View.
REACTOR_P2P_ENDPOINTS_TIMEOUT_MS=12000

# Default local server port used by the local server.
DEFAULT_LOCAL_SERVER_PORT=9063

# Reactor exchange status debounce time (milliseconds)
REACTOR_EXCHANGE_STATUS_DEBOUNCE_MS=250