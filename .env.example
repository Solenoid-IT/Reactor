# Copy this file to .env and customize values for your server setup.
# Example:
#   cp .env.example .env

# Exchange public listening port (HTTP + WS/WSS)
REACTOR_EXCHANGE_PORT=7070

# Optional token shared by all nodes.
# If empty, generate it at runtime with daemonctl.js.
REACTOR_EXCHANGE_TOKEN=

# Client role settings
REACTOR_CLIENT_PORT=7071
REACTOR_EXCHANGE_HOST=reactor-exchange
REACTOR_EXCHANGE_TLS=false

# TURN/STUN server (coturn)
COTURN_REALM=reactor.local
COTURN_USER=reactor
COTURN_PASSWORD=change-me-now
# Public IP/DNS reachable by peers (required for production NAT traversal)
COTURN_EXTERNAL_IP=
COTURN_PORT=3478
COTURN_TLS_PORT=5349
COTURN_TLS_CERT_PATH=/var/lib/coturn/certs/cert.pem
COTURN_TLS_KEY_PATH=/var/lib/coturn/certs/key.pem
COTURN_MIN_RELAY_PORT=49160
COTURN_MAX_RELAY_PORT=49200
