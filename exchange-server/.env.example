# Copy this file to .env and customize values for your server setup.
# Example:
#   cp .env.example .env

# Server port
PORT=7070

# TLS Encryption (HTTPS/WSS)
TLS=false

# TLS termination mode:
# - direct: Exchange serves HTTPS/WSS on PORT using cert.pem/key.pem
# - proxy: Exchange serves HTTP/WS on PORT, TLS is terminated by reverse proxy
TLS_MODE=direct

# TLS certificate reload interval in milliseconds (direct mode only)
REACTOR_EXCHANGE_TLS_RELOAD_INTERVAL_MS=5000

# Legacy/explicit switch for proxy TLS termination (optional)
# TLS_PROXY=true

# Token for authenticating nodes with the server
TOKEN=
